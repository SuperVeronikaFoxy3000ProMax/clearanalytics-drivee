# Скопируйте в `.env` в корне проекта (или заведите отдельный `.env.telegram` — см. ниже).

# Telegram: бот (`telegram_bot.py`) и рассылка из `api.py`
TELEGRAM_BOT_TOKEN=

# Вариант «только Telegram»: положите рядом файл `.env.telegram` с одной строкой:
# TELEGRAM_BOT_TOKEN=123456789:AA...
# Он подхватывается после `.env` и может хранить токен отдельно от остальных секретов.
